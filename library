			-- Section Header
			local SectHeader = Instance.new("TextLabel")
			SectHeader.Name = "SectHeader"
			SectHeader.BackgroundTransparency = 1
			SectHeader.Size = UDim2.new(1, 0, 0, 24)
			SectHeader.Font = Enum.Font.SourceSansBold
			SectHeader.Text = sectionName
			SectHeader.TextColor3 = Color3.fromRGB(140, 120, 255)
			SectHeader.TextScaled = true
			SectHeader.TextWrapped = true
			SectHeader.ZIndex = 2
