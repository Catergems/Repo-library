		TabBtn.TextScaled = true
		TabBtn.TextWrapped = true
		TabBtn.Parent = TabBarScrolling
		Corner(TabBtn, 6)

		table.insert(self._allTabBtns, TabBtn)

		-- Tab Content Frame
