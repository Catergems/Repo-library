			-- Items list
			local ItemList = Instance.new("Frame")
			ItemList.BackgroundTransparency = 1
			ItemList.BorderSizePixel = 0
			ItemList.Position = UDim2.new(0, 0, 0, 26)
			ItemList.Size = UDim2.new(1, 0, 0, 0)
			ItemList.AutomaticSize = Enum.AutomaticSize.Y
			ItemList.Parent = SectWrapper

			local IList = Instance.new("UIListLayout")
			IList.FillDirection = Enum.FillDirection.Vertical
			IList.HorizontalAlignment = Enum.HorizontalAlignment.Center
			IList.Padding = UDim.new(0, 4)
			IList.Parent = ItemList

			local IPad = Instance.new("UIPadding")
			IPad.PaddingLeft = UDim.new(0, 6)
			IPad.PaddingRight = UDim.new(0, 6)
			IPad.PaddingBottom = UDim.new(0, 6)
			IPad.Parent = ItemList

			local sg = self._sg

			-- Section object
			local Section = {}
			Section._header = SectHeader
			Section._items = ItemList
			Section._sg = sg

			-- sect:set("NewName") — update section title
			function Section:set(newName)
				self._header.Text = newName
			end

			-- ========================
			-- sect:CreateButton("Name","Desc",func)
			-- ========================
			function Section:CreateButton(name, desc, callback)
				callback = callback or function() end

				local Btn = Instance.new("TextButton")
				Btn.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
				Btn.BorderSizePixel = 0
				Btn.Size = UDim2.new(1, 0, 0, 30)
				Btn.Font = Enum.Font.SourceSansBold
				Btn.Text = name
				Btn.TextColor3 = Color3.fromRGB(230, 230, 230)
				Btn.TextScaled = true
				Btn.Parent = self._items
				Corner(Btn, 5)
				Stroke(Btn, Color3.fromRGB(65,60,110), 1)

				Btn.MouseEnter:Connect(function()
					Tween(Btn, {BackgroundColor3 = Color3.fromRGB(70,60,160)})
					if desc and desc ~= "" then ShowTooltip(sg, desc) end
				end)
				Btn.MouseLeave:Connect(function()
					Tween(Btn, {BackgroundColor3 = Color3.fromRGB(40,40,55)})
					HideTooltip()
				end)
				Btn.MouseButton1Click:Connect(function()
					callback()
				end)

				return Btn
			end

			-- ========================
			-- sect:CreateToggle("Name","Desc",default,func)
			-- ========================
			function Section:CreateToggle(name, desc, default, callback)
				callback = callback or function() end
				local state = default or false

				local Container = Instance.new("Frame")
				Container.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
				Container.BorderSizePixel = 0
				Container.Size = UDim2.new(1, 0, 0, 30)
				Container.Parent = self._items
				Corner(Container, 5)
				Stroke(Container, Color3.fromRGB(65,60,110), 1)

				local NameLbl = Instance.new("TextLabel")
				NameLbl.BackgroundTransparency = 1
				NameLbl.Position = UDim2.new(0, 8, 0, 0)
				NameLbl.Size = UDim2.new(0.6, 0, 1, 0)
				NameLbl.Font = Enum.Font.SourceSansBold
				NameLbl.Text = name
				NameLbl.TextColor3 = Color3.fromRGB(230, 230, 230)
				NameLbl.TextScaled = true
				NameLbl.TextXAlignment = Enum.TextXAlignment.Left
				NameLbl.Parent = Container

				local Track = Instance.new("Frame")
				Track.Size = UDim2.new(0, 38, 0, 18)
				Track.Position = UDim2.new(1, -46, 0.5, -9)
				Track.BackgroundColor3 = state and Color3.fromRGB(90,70,200) or Color3.fromRGB(55,55,70)
				Track.BorderSizePixel = 0
				Track.Parent = Container
				Corner(Track, 9)

				local Knob = Instance.new("Frame")
				Knob.Size = UDim2.new(0, 14, 0, 14)
				Knob.Position = state and UDim2.new(1,-16,0.5,-7) or UDim2.new(0,2,0.5,-7)
				Knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
				Knob.BorderSizePixel = 0
				Knob.Parent = Track
				Corner(Knob, 7)

				local Click = Instance.new("TextButton")
				Click.Size = UDim2.new(1,0,1,0)
				Click.BackgroundTransparency = 1
				Click.Text = ""
				Click.Parent = Container

				Click.MouseEnter:Connect(function()
					Tween(Container, {BackgroundColor3 = Color3.fromRGB(55,50,80)})
					if desc and desc ~= "" then ShowTooltip(sg, desc) end
				end)
				Click.MouseLeave:Connect(function()
					Tween(Container, {BackgroundColor3 = Color3.fromRGB(40,40,55)})
					HideTooltip()
				end)
				Click.MouseButton1Click:Connect(function()
					state = not state
					Tween(Track, {BackgroundColor3 = state and Color3.fromRGB(90,70,200) or Color3.fromRGB(55,55,70)})
					Tween(Knob, {Position = state and UDim2.new(1,-16,0.5,-7) or UDim2.new(0,2,0.5,-7)})
					callback(state)
				end)

				callback(state)

				return {
					GetState = function() return state end,
					SetState = function(s)
						state = s
						Tween(Track, {BackgroundColor3 = state and Color3.fromRGB(90,70,200) or Color3.fromRGB(55,55,70)})
						Tween(Knob, {Position = state and UDim2.new(1,-16,0.5,-7) or UDim2.new(0,2,0.5,-7)})
						callback(state)
					end
				}
			end

			-- ========================
			-- sect:CreateDropbox("Name","Desc",items,func)
			-- dropbox:refresh(newItems)
			-- ========================
			function Section:CreateDropbox(name, desc, items, callback)
				callback = callback or function() end
				items = items or {}
				local selected = items[1]
				local open = false

				local Wrapper = Instance.new("Frame")
				Wrapper.BackgroundTransparency = 1
				Wrapper.BorderSizePixel = 0
				Wrapper.Size = UDim2.new(1, 0, 0, 30)
				Wrapper.ClipsDescendants = false
				Wrapper.Parent = self._items

				local Container = Instance.new("Frame")
				Container.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
				Container.BorderSizePixel = 0
				Container.Size = UDim2.new(1, 0, 0, 30)
				Container.Parent = Wrapper
				Corner(Container, 5)
				Stroke(Container, Color3.fromRGB(65,60,110), 1)

				local NameLbl = Instance.new("TextLabel")
				NameLbl.BackgroundTransparency = 1
				NameLbl.Position = UDim2.new(0, 8, 0, 0)
				NameLbl.Size = UDim2.new(0.55, 0, 1, 0)
				NameLbl.Font = Enum.Font.SourceSansBold
				NameLbl.Text = name
				NameLbl.TextColor3 = Color3.fromRGB(230, 230, 230)
				NameLbl.TextScaled = true
				NameLbl.TextXAlignment = Enum.TextXAlignment.Left
				NameLbl.Parent = Container

				local SelectBtn = Instance.new("TextButton")
				SelectBtn.BackgroundColor3 = Color3.fromRGB(70,60,160)
				SelectBtn.BorderSizePixel = 0
				SelectBtn.Position = UDim2.new(1, -108, 0.5, -11)
				SelectBtn.Size = UDim2.new(0, 100, 0, 22)
				SelectBtn.Font = Enum.Font.SourceSansBold
				SelectBtn.Text = (selected or "None") .. " ▾"
				SelectBtn.TextColor3 = Color3.fromRGB(255,255,255)
				SelectBtn.TextScaled = true
				SelectBtn.Parent = Container
				Corner(SelectBtn, 5)

				-- Dropdown list
				local DropFrame = Instance.new("Frame")
				DropFrame.BackgroundColor3 = Color3.fromRGB(30,30,45)
				DropFrame.BorderSizePixel = 0
				DropFrame.Position = UDim2.new(1,-108, 1, 4)
				DropFrame.Size = UDim2.new(0, 100, 0, 0)
				DropFrame.Visible = false
				DropFrame.ZIndex = 50
				DropFrame.ClipsDescendants = true
				DropFrame.Parent = Container
				Corner(DropFrame, 5)
				Stroke(DropFrame, Color3.fromRGB(65,60,110), 1)

				local DropList = Instance.new("UIListLayout")
				DropList.FillDirection = Enum.FillDirection.Vertical
				DropList.Parent = DropFrame

				local function PopulateDropbox(itemList)
					-- Clear old items
					for _, c in pairs(DropFrame:GetChildren()) do
						if c:IsA("TextButton") then c:Destroy() end
					end
					for _, item in ipairs(itemList) do
						local ItemBtn = Instance.new("TextButton")
						ItemBtn.BackgroundColor3 = Color3.fromRGB(38,38,55)
						ItemBtn.BorderSizePixel = 0
						ItemBtn.Size = UDim2.new(1, 0, 0, 24)
						ItemBtn.Font = Enum.Font.SourceSans
						ItemBtn.Text = tostring(item)
						ItemBtn.TextColor3 = Color3.fromRGB(220,220,220)
						ItemBtn.TextScaled = true
						ItemBtn.ZIndex = 51
						ItemBtn.Parent = DropFrame
						Corner(ItemBtn, 4)

						ItemBtn.MouseEnter:Connect(function()
							Tween(ItemBtn, {BackgroundColor3 = Color3.fromRGB(70,60,160)})
						end)
						ItemBtn.MouseLeave:Connect(function()
							Tween(ItemBtn, {BackgroundColor3 = Color3.fromRGB(38,38,55)})
						end)
						ItemBtn.MouseButton1Click:Connect(function()
							selected = tostring(item)
							SelectBtn.Text = selected .. " ▾"
							open = false
							Tween(DropFrame, {Size = UDim2.new(0,100,0,0)}, 0.15)
							task.delay(0.15, function() DropFrame.Visible = false end)
							callback(selected)
						end)
					end
					-- update size
					DropFrame.Size = UDim2.new(0, 100, 0, #itemList * 24)
				end

				PopulateDropbox(items)

				SelectBtn.MouseButton1Click:Connect(function()
					open = not open
					if open then
						DropFrame.Size = UDim2.new(0,100,0,0)
						DropFrame.Visible = true
						Tween(DropFrame, {Size = UDim2.new(0,100,0,#items * 24)}, 0.15)
					else
						Tween(DropFrame, {Size = UDim2.new(0,100,0,0)}, 0.15)
						task.delay(0.15, function() DropFrame.Visible = false end)
					end
				end)

				Container.MouseEnter:Connect(function()
					if desc and desc ~= "" then ShowTooltip(sg, desc) end
				end)
				Container.MouseLeave:Connect(function()
					HideTooltip()
				end)

				-- Dropbox object
				local Dropbox = {}
				Dropbox._items = items
				Dropbox._selectBtn = SelectBtn

				-- dropbox:refresh(newItems)
				function Dropbox:refresh(newItems)
					newItems = newItems or {}
					items = newItems
					self._items = newItems
					selected = newItems[1]
					SelectBtn.Text = (selected or "None") .. " ▾"
					PopulateDropbox(newItems)
					-- close if open
					open = false
					DropFrame.Visible = false
				end

				function Dropbox:GetSelected()
					return selected
				end

				return Dropbox
			end

			-- ========================
			-- sect:keybind("Name", Enum.KeyCode.X, func)
			-- ========================
			function Section:keybind(name, defaultKey, callback)
				callback = callback or function() end
				local currentKey = defaultKey
				local listening = false

				local Container = Instance.new("Frame")
				Container.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
				Container.BorderSizePixel = 0
				Container.Size = UDim2.new(1, 0, 0, 30)
				Container.Parent = self._items
				Corner(Container, 5)
				Stroke(Container, Color3.fromRGB(65,60,110), 1)

				local NameLbl = Instance.new("TextLabel")
				NameLbl.BackgroundTransparency = 1
				NameLbl.Position = UDim2.new(0, 8, 0, 0)
				NameLbl.Size = UDim2.new(0.55, 0, 1, 0)
				NameLbl.Font = Enum.Font.SourceSansBold
				NameLbl.Text = name
				NameLbl.TextColor3 = Color3.fromRGB(230, 230, 230)
				NameLbl.TextScaled = true
				NameLbl.TextXAlignment = Enum.TextXAlignment.Left
				NameLbl.Parent = Container

				local KeyBtn = Instance.new("TextButton")
				KeyBtn.BackgroundColor3 = Color3.fromRGB(70, 60, 160)
				KeyBtn.BorderSizePixel = 0
				KeyBtn.Position = UDim2.new(1, -108, 0.5, -11)
				KeyBtn.Size = UDim2.new(0, 100, 0, 22)
				KeyBtn.Font = Enum.Font.SourceSansBold
				KeyBtn.Text = "[" .. currentKey.Name .. "]"
				KeyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
				KeyBtn.TextScaled = true
				KeyBtn.Parent = Container
				Corner(KeyBtn, 5)

				KeyBtn.MouseButton1Click:Connect(function()
					if listening then return end
					listening = true
					KeyBtn.Text = "..."
					KeyBtn.BackgroundColor3 = Color3.fromRGB(180, 140, 30)
				end)

				UIS.InputBegan:Connect(function(input, gpe)
					if listening and input.UserInputType == Enum.UserInputType.Keyboard then
						listening = false
						currentKey = input.KeyCode
						KeyBtn.Text = "[" .. currentKey.Name .. "]"
						KeyBtn.BackgroundColor3 = Color3.fromRGB(70, 60, 160)
					elseif not gpe and not listening and input.KeyCode == currentKey then
						callback()
					end
				end)

				return {
					GetKey = function() return currentKey end,
					SetKey = function(newKey)
						currentKey = newKey
						KeyBtn.Text = "[" .. currentKey.Name .. "]"
					end
				}
			end

			return Section
		end

		return Tab
	end

	return Window
end

return Library
