		task.delay(0.2, function()
			Main.Visible = false
			Main.Size = UDim2.new(0.540515959, 0, 0.574608922, 0)
		end)
	end

	-- window:show()
	function Window:show()
		Main.Size = UDim2.new(0, 0, 0, 0)
		Main.Visible = true
		Tween(Main, {Size = UDim2.new(0.540515959, 0, 0.574608922, 0)}, 0.2)
	end

