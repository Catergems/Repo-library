		TabScroll.Position = UDim2.new(0, 4, 0, 0)
		TabScroll.ScrollBarThickness = 3
		TabScroll.ScrollBarImageColor3 = Color3.fromRGB(80,80,130)
		TabScroll.CanvasSize = UDim2.new(0,0,0,0)
		TabScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
		TabScroll.Parent = TabFrame

		-- Link tab frame to content area
		TabFrame.Parent = ContentArea

		local SectList = Instance.new("UIListLayout")
		SectList.FillDirection = Enum.FillDirection.Vertical
		SectList.HorizontalAlignment = Enum.HorizontalAlignment.Center
		SectList.Padding = UDim.new(0, 6)
		SectList.Parent = TabScroll

		local Pad = Instance.new("UIPadding")
		Pad.PaddingTop = UDim.new(0, 6)
		Pad.PaddingLeft = UDim.new(0, 4)
		Pad.PaddingRight = UDim.new(0, 4)
		Pad.Parent = TabScroll

		local allBtns = self._allTabBtns

		TabBtn.MouseButton1Click:Connect(function()
			SelectTab(TabFrame, TabBtn, allBtns)
		end)

		-- Auto-select first tab
		if #self._allTabBtns == 1 then
			SelectTab(TabFrame, TabBtn, allBtns)
		end

		-- Tab object
		local Tab = {}
		Tab._scroll = TabScroll
		Tab._sg = SG

		-- tab:CreateSection("SectionName")
		function Tab:CreateSection(sectionName)
			local SectWrapper = Instance.new("Frame")
