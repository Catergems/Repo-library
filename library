			local SectSep = Instance.new("Frame")
			SectSep.BackgroundColor3 = Color3.fromRGB(50,50,60)
			SectSep.BorderSizePixel = 0
			SectSep.Position = UDim2.new(0.03, 0, 0, 24)
			SectSep.Size = UDim2.new(0.94, 0, 0, 1)
